    "run": {
      "output_root": "output/runs",
      "random_seed": 20260429,
      "test_size": 0.2,
      "valid_size": 0.2,
      "primary_metric": "roc_auc",
      "threshold_strategy": "balanced_youden_f1",
      "min_auc_warning": 0.7,
      "max_fpr_warning": 0.4,
      "min_recall_warning": 0.05,
      "all_negative_rate_warning": 0.98
    },
    "dataset": {
      "endpoint_name": "heart_related_event_by_2020",
      "baseline_year": 2011,
      "horizon_year": 2020,
      "include_blood_enhanced_features": false,
      "min_fi_observed_fraction": 0.2
    },
    "training": {
      "optuna_trials": 10,
      "optuna_timeout_seconds": 240,
      "models": [
        "logistic_regression",
        "random_forest",
        "xgboost",
        "lightgbm",
        "catboost"
      ],
      "feature_sets": {
        "primary": {
          "description": "主分析特征集，保留 2011 基线 FI、人口学、生活方式、慢病、功能和体测变量。",
          "exclude": []
        },
        "no_body_size_demographic": {
          "description": "敏感性分析特征集，去掉年龄、性别、身高、体重、BMI、腰围等粗变量，检查模型是否仍能从 FI/健康缺陷中获得信号。",
          "exclude": [
            "age_2011",
            "sex_code_2011",
            "height_cm_2011",
            "weight_kg_2011",
            "bmi_2011",
            "waist_cm_2011"
          ]
        }
      }
    },
    "interpretability": {
      "require_shap": true,
      "shap_background_size": 300,
      "shap_explain_size": 500,
      "top_n_features": 20
    },
    "archive": {
      "enabled": true,
      "directory": "output/share",
      "keep_latest_only": true
    }
  }
